/*
 * Synopsys 28nm Standard Cell Library for ABC
 * Based on Synopsys Fusion Compiler 28nm technology
 *
 * This library is intended for use with ABC (read_lib command)
 * for Boolean function decomposition and technology mapping.
 *
 * Area values from Synopsys 28nm library (relative units).
 * Timing/capacitance values are nominal placeholders.
 */
library(synopsys28nm) {

  delay_model : table_lookup;
  time_unit : "1ns";
  voltage_unit : "1V";
  current_unit : "1uA";
  capacitive_load_unit (1,pf);

  nom_voltage : 0.9;
  nom_temperature : 25;

  /* ============================== */
  /* Inverter                       */
  /* ============================== */
  cell (INV) {
    area : 0.34;
    pin(A) {
      direction : input;
      capacitance : 0.001;
    }
    pin(Y) {
      direction : output;
      function : "(!A)";
      timing() {
        related_pin : "A";
        timing_sense : negative_unate;
        cell_rise(scalar) { values("0.01"); }
        cell_fall(scalar) { values("0.01"); }
        rise_transition(scalar) { values("0.01"); }
        fall_transition(scalar) { values("0.01"); }
      }
    }
  }

  /* ============================== */
  /* AND gates                      */
  /* ============================== */
  cell (AN2) {
    area : 0.68;
    pin(A) {
      direction : input;
      capacitance : 0.001;
    }
    pin(B) {
      direction : input;
      capacitance : 0.001;
    }
    pin(Y) {
      direction : output;
      function : "(A B)";
      timing() {
        related_pin : "A";
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.02"); }
        cell_fall(scalar) { values("0.02"); }
        rise_transition(scalar) { values("0.02"); }
        fall_transition(scalar) { values("0.02"); }
      }
      timing() {
        related_pin : "B";
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.02"); }
        cell_fall(scalar) { values("0.02"); }
