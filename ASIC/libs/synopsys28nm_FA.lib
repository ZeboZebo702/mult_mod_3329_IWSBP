        fall_transition(scalar) { values("0.04"); }
      }
      timing() {
        related_pin : "B";
        timing_sense : non_unate;
        cell_rise(scalar) { values("0.04"); }
        cell_fall(scalar) { values("0.04"); }
        rise_transition(scalar) { values("0.04"); }
        fall_transition(scalar) { values("0.04"); }
      }
    }
  }

  /* ============================== */
  /* MUX (inverted output)          */
  /* MUXI2: Y = !S*A + S*!B        */
  /* ============================== */
  cell (MUXI2) {
    area : 1.01;
    pin(A) {
      direction : input;
      capacitance : 0.001;
    }
    pin(B) {
      direction : input;
      capacitance : 0.001;
    }
    pin(S) {
      direction : input;
      capacitance : 0.001;
    }
    pin(Y) {
      direction : output;
      function : "((!S A)+(S !B))";
      timing() {
        related_pin : "A";
        timing_sense : non_unate;
        cell_rise(scalar) { values("0.03"); }
        cell_fall(scalar) { values("0.03"); }
        rise_transition(scalar) { values("0.03"); }
        fall_transition(scalar) { values("0.03"); }
      }
      timing() {
        related_pin : "B";
        timing_sense : non_unate;
        cell_rise(scalar) { values("0.03"); }
        cell_fall(scalar) { values("0.03"); }
        rise_transition(scalar) { values("0.03"); }
        fall_transition(scalar) { values("0.03"); }
      }
      timing() {
        related_pin : "S";
        timing_sense : non_unate;
        cell_rise(scalar) { values("0.03"); }
        cell_fall(scalar) { values("0.03"); }
        rise_transition(scalar) { values("0.03"); }
        fall_transition(scalar) { values("0.03"); }
      }
    }
  }

  /* ============================== */
  /* Enable gate (functionally AND) */
  /* ============================== */
  cell (EN2) {
    area : 1.35;
    pin(A) {
      direction : input;
      capacitance : 0.001;
    }
    pin(EN) {
      direction : input;
      capacitance : 0.001;
    }
    pin(Y) {
      direction : output;
      function : "(A EN)";
      timing() {
        related_pin : "A";
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.03"); }
        cell_fall(scalar) { values("0.03"); }
        rise_transition(scalar) { values("0.03"); }
        fall_transition(scalar) { values("0.03"); }
      }
      timing() {
        related_pin : "EN";
        timing_sense : positive_unate;
        cell_rise(scalar) { values("0.03"); }
        cell_fall(scalar) { values("0.03"); }
        rise_transition(scalar) { values("0.03"); }
        fall_transition(scalar) { values("0.03"); }
      }
    }
  }

}
